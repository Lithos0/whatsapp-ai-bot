{
  "name": "whatsapp-ai-bot",
  "version": "1.0.0",
  "description": "Bot de WhatsApp con IA usando whatsapp-web.js y Google Gemini",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop whatsapp-ai-bot",
    "pm2:restart": "pm2 restart whatsapp-ai-bot",
    "pm2:logs": "pm2 logs whatsapp-ai-bot",
    "postinstall": "patch-package"
  },
  "keywords": [
    "whatsapp",
    "bot",
    "whatsapp-web.js",
    "gemini",
    "google",
    "ia"
  ],
  "author": "",
  "license": "MIT",
  "overrides": {
    "basic-ftp": "5.2.2",
    "follow-redirects": "1.16.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "dotenv": "^16.4.5",
    "patch-package": "^8.0.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.34.6"
  },
  "devDependencies": {
    "pm2": "^6.0.14"
  }
}
