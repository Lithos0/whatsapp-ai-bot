# Copiar a .env y rellenar (no commitear .env)
AI_API_KEY=
TARGET_GROUP_ID=
BOT_OWNER_PHONE=

# Opcional: umbral 50–99 para enviar [MODERADOR] (por defecto 88)
# MODERATION_PROBABILITY_MIN=88

# Fase 2: si es false, siempre se llama a Gemini (sin filtro por léxico)
# LEXICON_GATE_ENABLED=true

# Cola Gemini: ms mínimos entre el fin de una petición y el inicio de la siguiente (default 15000)
# GEMINI_MIN_GAP_MS=15000
# Reintentos tras 429 (además del primer intento). Default 5 reintentos = hasta 6 llamadas.
# GEMINI_429_MAX_RETRIES=5
# Espera base en ms antes del primer reintento (luego x2, x4…). Default 20000
# GEMINI_429_BASE_WAIT_MS=20000
